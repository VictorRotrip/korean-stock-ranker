# =============================================================================
# Korean Stock Ranker - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
# For mock data mode, no env vars are required — the app runs on built-in data.
# =============================================================================

# --- Supabase Postgres ---
# Required for real data. Get from: Supabase Dashboard → Settings → Database
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Data source switch ---
# "mock" = built-in mock data (no DB required)
# "db"   = read from Supabase (requires DATABASE_URL)
# If not set, auto-detects: uses DB when DATABASE_URL is present, mock otherwise
NEXT_PUBLIC_DATA_SOURCE=mock

# --- DART API (Phase 3 — financial statements) ---
# Register at https://opendart.fss.or.kr/ to get a free API key
# Free tier: ~1000 requests/day
DART_API_KEY=your-dart-api-key

# --- Optional ---
# NEXT_PUBLIC_APP_URL=http://localhost:3000
